const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

let player = {
x:50,
y:300,
w:30,
h:30,
dy:0,
jump:false
};

function game(){

ctx.clearRect(0,0,800,400);

ctx.fillStyle="green";
ctx.fillRect(0,350,800,50);

ctx.fillStyle="red";
ctx.fillRect(player.x,player.y,player.w,player.h);

player.y += player.dy;
player.dy += 0.5;

if(player.y>320){
player.y=320;
player.dy=0;
player.jump=false;
}

requestAnimationFrame(game);

}

document.addEventListener("keydown",e=>{

if(e.key=="ArrowRight")
player.x+=10;

if(e.key=="ArrowLeft")
player.x-=10;

if(e.code=="Space" && !player.jump){
player.dy=-10;
player.jump=true;
}

});

game();
